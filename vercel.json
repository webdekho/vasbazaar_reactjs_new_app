{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/customer/app/payment-callback",
      "methods": ["POST"],
      "dest": "/api/payment-callback"
    },
    {
      "src": "/customer/app/autopay-callback",
      "methods": ["POST"],
      "dest": "/api/autopay-callback"
    }
  ],
  "rewrites": [
    { "source": "/vb-api/:path*", "destination": "https://api.vasbazaar.com/:path*" },
    { "source": "/api/:path*", "destination": "https://api.vasbazaar.com/api/:path*" },
    { "source": "/login/:path*", "destination": "https://api.vasbazaar.com/login/:path*" },
    { "source": "/coupon/:path*", "destination": "https://api.vasbazaar.com/coupon/:path*" },
    { "source": "/user/:path*", "destination": "https://api.vasbazaar.com/user/:path*" },
    { "source": "/app/static/(.*)", "destination": "/static/$1" },
    { "source": "/customer/app/static/(.*)", "destination": "/static/$1" },
    { "source": "/customer/app/services/static/(.*)", "destination": "/static/$1" },
    { "source": "/customer/static/(.*)", "destination": "/static/$1" },
    { "source": "/app/manifest.json", "destination": "/manifest.json" },
    { "source": "/customer/app/manifest.json", "destination": "/manifest.json" },
    { "source": "/customer/app/services/manifest.json", "destination": "/manifest.json" },
    { "source": "/customer/manifest.json", "destination": "/manifest.json" },
    { "source": "/app/favicon.png", "destination": "/favicon.png" },
    { "source": "/customer/app/favicon.png", "destination": "/favicon.png" },
    { "source": "/customer/app/services/favicon.png", "destination": "/favicon.png" },
    { "source": "/customer/favicon.png", "destination": "/favicon.png" },
    { "source": "/app/icon-(.*)", "destination": "/icon-$1" },
    { "source": "/customer/app/icon-(.*)", "destination": "/icon-$1" },
    { "source": "/customer/app/services/icon-(.*)", "destination": "/icon-$1" },
    { "source": "/customer/icon-(.*)", "destination": "/icon-$1" },
    { "source": "/app/sw.js", "destination": "/sw.js" },
    { "source": "/customer/app/sw.js", "destination": "/sw.js" },
    { "source": "/customer/app/services/sw.js", "destination": "/sw.js" },
    { "source": "/customer/sw.js", "destination": "/sw.js" },
    { "source": "/app/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/customer/app/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/customer/app/services/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/customer/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/customer/(.*)", "destination": "/index.html" },
    { "source": "/((?!static|favicon|icon|manifest|sw|screenshot|assets|vb-api|api|login|coupon|user).*)", "destination": "/index.html" }
  ]
}
