platform :ios, '15.0'
use_frameworks!

# Silence all warnings coming from third-party pods
inhibit_all_warnings!

def capacitor_pods
  # Capacitor Core - using CocoaPods trunk
  pod 'Capacitor', '~> 8.3.0'
  pod 'CapacitorCordova', '~> 8.3.0'

  # Official Capacitor Plugins
  pod 'CapacitorApp', '~> 8.1.0'
  pod 'CapacitorBrowser', '~> 8.0.3'
  pod 'CapacitorCamera', '~> 8.2.0'
  pod 'CapacitorFilesystem', '~> 8.1.2'
  pod 'CapacitorGeolocation', '~> 8.2.0'
  pod 'CapacitorLocalNotifications', '~> 8.0.2'
  pod 'CapacitorPreferences', '~> 8.0.1'
  pod 'CapacitorPushNotifications', '~> 8.0.1'
  pod 'CapacitorShare', '~> 8.0.1'
  pod 'CapacitorStatusBar', '~> 8.0.2'

  # Community Plugins
  pod 'CapacitorCommunityContacts', '~> 7.1.0'
  pod 'CapacitorCommunityNativeAudio', '~> 8.0.0'

  # Capawesome Plugins
  pod 'CapawesomeTeamCapacitorFileOpener', '~> 8.0.1'

  # Other Plugins - using Git source
  pod 'AalzehlaCapacitorSmsRetriever', :git => 'https://github.com/AalzehlaCapacitorSmsRetriever/aalzehla-capacitor-sms-retriever.git', :tag => '0.0.9'
end

target 'App' do
  capacitor_pods
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'
    end
  end
end
